{
  "expo": {
    "name": "Loom",
    "slug": "loom-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "loom",
    "android": {
      "package": "cloud.furevikstrand.loom",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "Loom uses the camera once, to scan the pairing QR on your laptop." }
      ]
    ]
  }
}
