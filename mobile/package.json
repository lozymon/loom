{
  "name": "loom-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Loom — local-first Android app (Plan 02 L2). Drives a Loom fleet over the sealed LAN bridge.",
  "main": "index.ts",
  "scripts": {
